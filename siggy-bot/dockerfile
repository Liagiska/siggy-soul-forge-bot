FROM python:3.11-slim

WORKDIR /app

# Copy requirements dan install
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy semua file project
COPY . .

# Expose port
EXPOSE 7860

# Run dengan gunicorn
CMD ["gunicorn", "--bind", "0.0.0.0:7860", "--workers", "2", "app:app"]